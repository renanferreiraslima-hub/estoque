# Porta em que o servidor backend vai rodar
PORT=3000

# Segredo usado para assinar os tokens JWT (troque por um valor aleatorio e seguro)
JWT_SECRET=troque_esta_chave_secreta_antes_de_usar_em_producao

# Tempo de expiracao do token JWT
JWT_EXPIRES_IN=8h

# Dados do usuario administrador criado automaticamente na primeira execucao
ADMIN_NOME=Administrador
ADMIN_EMAIL=admin@estoque.com
ADMIN_SENHA=admin123

# Configuracao da Evolution API (integracao com WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=coloque_sua_chave_da_evolution_api
EVOLUTION_INSTANCE=estoque

# Configuracao do webhook de cobranca via PIX
PIX_WEBHOOK_SECRET=chave_secreta_para_validar_o_webhook_pix

# Dias antes/depois do vencimento para disparar cobranca automatica de fiado
COBRANCA_DIAS_ANTES=1
COBRANCA_DIAS_ATRASO=3

# Horario (cron) em que a rotina diaria de cobranca e aniversario roda - padrao 09:00 todos os dias
COBRANCA_CRON=0 9 * * *
